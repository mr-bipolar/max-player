<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape>
            <solid android:color="#4D568D"/> <corners android:radius="14dp"/>
            <stroke
                android:width="3dp"
                android:color="#FFFFFF"/>
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="#B22A2F52"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#B43D4371"/> <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#20FFFFFF"/> </shape>
    </item>

</selector>