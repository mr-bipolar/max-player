<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <gradient
                android:startColor="#4A538A"
                android:endColor="#313966"
                android:angle="270"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="3dp"
                android:color="#FFFFFF"/> </shape>
    </item>

    <item>
        <shape>
            <gradient
                android:startColor="#3D4371"
                android:endColor="#2A2F52"
                android:angle="270"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="1dp"
                android:color="#565E8D"/>
        </shape>
    </item>
</selector>
