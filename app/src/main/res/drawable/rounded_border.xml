<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <gradient android:startColor="#607D8B" android:endColor="#455A64" android:angle="270"/>
            <corners android:radius="12dp"/>
            <stroke android:width="3dp" android:color="#FFFFFF"/> </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#30FFFFFF"/> <corners android:radius="12dp"/>
            <stroke android:width="1dp" android:color="#20FFFFFF"/>
        </shape>
    </item>
</selector>
