<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/movie_tv_card"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="@drawable/bg_tv_selector"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:clickable="true"
    android:descendantFocusability="afterDescendants">

<!-- Channel Number -->
    <!-- IMAGE AREA -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:padding="10dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
      >

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/posterImg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerInside"
                app:layout_constraintDimensionRatio="3:3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/RoundedCornersImage" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

<!-- Channel Name -->
<TextView
    android:id="@+id/titleTxt"
    android:layout_width="0dp"
    android:layout_weight="1"
    android:layout_height="wrap_content"
    android:textColor="@android:color/white"
    android:fontFamily="@font/inter_medium"
    android:maxLines="1"
    android:paddingLeft="18dp"
    android:textSize="18sp"/>

<!-- Price -->
    <ImageButton
        android:visibility="invisible"
        android:id="@+id/favBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_margin="20dp"
        android:layout_gravity="center_vertical"
        android:background="@drawable/bg_fav_glass"
        android:src="@drawable/bookmark_add"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:clickable="false"
        app:tint="@color/primary_dark" />

</LinearLayout>