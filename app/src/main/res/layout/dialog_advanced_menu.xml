<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="@drawable/bg_dialog_card"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="?android:dividerHorizontal"
        android:showDividers="middle">

        <!-- Video controls row 1 -->
        <TableRow
            android:id="@+id/rowVideo1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp">

            <Button
                android:id="@+id/contrastBtn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_contrast"
                android:drawablePadding="8dp"
                android:text="@string/contrast"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/brightnessBtn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_brightness"
                android:drawablePadding="8dp"
                android:text="@string/video_brightness"
                android:textAllCaps="false" />
        </TableRow>

        <!-- Video controls row 2 -->
        <TableRow
            android:id="@+id/rowVideo2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp">

            <Button
                android:id="@+id/gammaBtn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_gamma"
                android:drawablePadding="8dp"
                android:text="@string/gamma"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/saturationBtn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_saturation"
                android:drawablePadding="8dp"
                android:text="@string/saturation"
                android:textAllCaps="false" />
        </TableRow>

        <!-- Subtitle seek -->
        <TableRow
            android:id="@+id/rowSubSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="6dp">

            <Button
                android:id="@+id/subSeekBtn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:drawableStart="@drawable/ic_subtitles_black_24dp"
                android:drawablePadding="8dp"
                android:text="@string/sub_seek_button"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/subSeekPrev"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/alpha_darken"
                android:drawableStart="@drawable/ic_skip_previous_black_24dp"
                android:text="@string/dialog_prev"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/subSeekNext"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/alpha_darken"
                android:drawableEnd="@drawable/ic_skip_next_black_24dp"
                android:text="@string/dialog_next"
                android:textAllCaps="false" />
        </TableRow>

        <!-- Stats -->
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="6dp">

            <Button
                android:id="@+id/statsBtn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:drawableStart="@drawable/ic_stats"
                android:drawablePadding="8dp"
                android:text="@string/toggle_stats"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/statsBtn1"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/alpha_darken"
                android:text="1" />

            <Button
                android:id="@+id/statsBtn2"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/alpha_darken"
                android:text="2" />

            <Button
                android:id="@+id/statsBtn3"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/alpha_darken"
                android:text="3" />
        </TableRow>

        <!-- Audio / Sub delay -->
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="6dp">

            <Button
                android:id="@+id/audioDelayBtn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_audio_delay"
                android:drawablePadding="8dp"
                android:text="@string/audio_delay"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/subDelayBtn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_sub_delay"
                android:drawablePadding="8dp"
                android:text="@string/sub_delay"
                android:textAllCaps="false" />
        </TableRow>

        <!-- Aspect ratio -->
        <Button
            android:id="@+id/aspectBtn"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_aspect_ratio"
            android:drawablePadding="8dp"
            android:text="@string/aspect_ratio"
            android:textAllCaps="false" />

    </LinearLayout>

</ScrollView>
