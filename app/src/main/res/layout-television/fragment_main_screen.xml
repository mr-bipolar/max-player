<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical"
    android:orientation="vertical"
    android:paddingHorizontal="24dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"

        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

        <FrameLayout
            android:visibility="gone"
            android:id="@+id/docBtn"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_glass_card"
            android:elevation="4dp"
            android:padding="16dp"
            android:layout_marginEnd="30dp"
            >

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_rounded"
                android:elevation="12dp"
                android:padding="10dp"
                android:src="@drawable/outline_folder_24"
                app:tint="@color/accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="78dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:text="Local Folder"
                    android:textColor="@color/colorPrimaryText"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/action_open_doc_tree"
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>


        <FrameLayout
            android:id="@+id/urlBtn"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_glass_card"
            android:elevation="4dp"
            android:padding="16dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="10dp"
            >

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_rounded"
                android:elevation="12dp"
                android:padding="10dp"
                android:src="@drawable/link_2_24"

                app:tint="@color/accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="78dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:text="Playlist Link"
                    android:textColor="@color/colorPrimaryText"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/action_open_url"
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>

            <FrameLayout
                android:id="@+id/urlBtn2"
                android:layout_width="380dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_glass_card"
                android:elevation="4dp"
                android:padding="16dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginVertical="10dp"
                >

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_rounded"
                    android:elevation="12dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_background_play_24dp"
                    app:tint="@color/accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="78dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="Video URL"
                        android:textColor="@color/colorPrimaryText"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stream Direct URL"
                        android:textColor="@color/colorSecondaryText"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/filepickerBtn"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="10dp"
            android:background="@drawable/bg_glass_card"
            android:elevation="4dp"
            android:padding="16dp"

            >

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_rounded"
                android:elevation="12dp"
                android:padding="10dp"
                android:src="@drawable/outline_file_open_24"
                app:tint="@color/accent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="78dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:text="File Picker"
                    android:textColor="@color/colorPrimaryText"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose File"
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>





        <FrameLayout
            android:id="@+id/settingsBtn"
            android:layout_width="380dp"
            android:layout_height="100dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="10dp"
            android:background="@drawable/bg_glass_card"
            android:elevation="4dp"
            android:padding="16dp"
            >

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_image"
                android:backgroundTint="#E4B442"
                android:elevation="8dp"
                android:padding="10dp"
                android:src="@drawable/help_48"
                app:tint="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="78dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:text="Don't have a playlist?"
                    android:textColor="@color/colorPrimaryText"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Learn where to get M3U links."
                    android:textColor="@color/colorSecondaryText"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <FrameLayout
                android:visibility="gone"

                android:layout_width="380dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_glass_card"
                android:elevation="4dp"
                android:padding="16dp"
                android:layout_marginEnd="30dp"
                >

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_rounded"
                    android:elevation="12dp"
                    android:padding="10dp"
                    android:src="@drawable/outline_folder_24"
                    app:tint="@color/accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="78dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="Local Folder"
                        android:textColor="@color/colorPrimaryText"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/action_open_doc_tree"
                        android:textColor="@color/colorSecondaryText"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>


            <FrameLayout
                android:id="@+id/aboutBtn"
                android:layout_width="380dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_glass_card"
                android:elevation="4dp"
                android:padding="16dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginVertical="10dp"
                >

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_rounded"
                    android:elevation="12dp"
                    android:padding="10dp"
                    android:src="@drawable/info_48"
                    android:tintMode="@color/accent"
                    app:tint="@color/accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="78dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="About"
                        android:textColor="@color/colorPrimaryText"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="App info &amp; version"
                        android:textColor="@color/colorSecondaryText"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/licenseInfo"
                android:layout_width="380dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_glass_card"
                android:elevation="4dp"
                android:padding="16dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginVertical="10dp"
                >

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_rounded"
                    android:elevation="12dp"
                    android:padding="10dp"
                    android:src="@drawable/copyright_24"
                    app:tint="@color/accent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="78dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="Open Source"
                        android:textColor="@color/colorPrimaryText"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Licenses &amp; credits"
                        android:textColor="@color/colorSecondaryText"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>




    </LinearLayout>


    <androidx.appcompat.widget.SwitchCompat
        android:visibility="gone"
        android:id="@+id/switch1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:padding="16dp"
        android:textColor="@color/accent"
        android:text="@string/option_remember_choice"
        android:fontFamily="@font/inter_medium"
        android:textSize="15sp"
        app:showText="false"
        app:thumbTint="@color/switch_thumb_selector"
        app:trackTint="@color/switch_track_selector"
        />



</LinearLayout>
